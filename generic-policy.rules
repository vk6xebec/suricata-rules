alert tcp $EXTERNAL_NET any -> $HOME_NET 445 (msg:"GENERIC POLICY inbound SMB exposure attempt"; flow:to_server; detection_filter:track by_src, count 1, seconds 600; classtype:attempted-recon; sid:9900501; rev:1; metadata: policy exposed_service, protocol SMB, confidence High, response_action alert_only;)

alert tcp $EXTERNAL_NET any -> $HOME_NET 139 (msg:"GENERIC POLICY inbound NetBIOS session attempt"; flow:to_server; detection_filter:track by_src, count 1, seconds 600; classtype:attempted-recon; sid:9900502; rev:1; metadata: policy exposed_service, protocol NetBIOS, confidence High, response_action alert_only;)

alert tcp $EXTERNAL_NET any -> $HOME_NET 1433 (msg:"GENERIC POLICY inbound MSSQL exposure attempt"; flow:to_server; detection_filter:track by_src, count 1, seconds 600; classtype:attempted-recon; sid:9900503; rev:1; metadata: policy exposed_service, protocol MSSQL, confidence Medium, response_action alert_only;)

alert tcp $EXTERNAL_NET any -> $HOME_NET 3306 (msg:"GENERIC POLICY inbound MySQL exposure attempt"; flow:to_server; detection_filter:track by_src, count 1, seconds 600; classtype:attempted-recon; sid:9900504; rev:1; metadata: policy exposed_service, protocol MySQL, confidence Medium, response_action alert_only;)

alert tcp $EXTERNAL_NET any -> $HOME_NET 5432 (msg:"GENERIC POLICY inbound PostgreSQL exposure attempt"; flow:to_server; detection_filter:track by_src, count 1, seconds 600; classtype:attempted-recon; sid:9900505; rev:1; metadata: policy exposed_service, protocol PostgreSQL, confidence Medium, response_action alert_only;)

alert tcp $EXTERNAL_NET any -> $HOME_NET 6379 (msg:"GENERIC POLICY inbound Redis-compatible service exposure attempt"; flow:to_server; detection_filter:track by_src, count 1, seconds 600; classtype:attempted-recon; sid:9900506; rev:1; metadata: policy exposed_service, protocol Redis, confidence Medium, response_action alert_only;)

alert tcp $EXTERNAL_NET any -> $HOME_NET 9200 (msg:"GENERIC POLICY inbound search/index service exposure attempt"; flow:to_server; detection_filter:track by_src, count 1, seconds 600; classtype:attempted-recon; sid:9900507; rev:1; metadata: policy exposed_service, protocol Search_Index, confidence Medium, response_action alert_only;)


# ----------------------------------------------------------------------------
# 07_TIME_PROTOCOL_VISIBILITY
# ----------------------------------------------------------------------------

alert udp $HOME_NET any -> $EXTERNAL_NET 123 (msg:"GENERIC POLICY outbound NTP observed"; detection_filter:track by_src, count 1, seconds 600; classtype:misc-activity; sid:9900601; rev:1; metadata: policy time_integrity, protocol NTP, confidence Low, response_action alert_only;)

alert udp $EXTERNAL_NET any -> $HOME_NET 123 (msg:"GENERIC POLICY inbound NTP attempt"; detection_filter:track by_src, count 1, seconds 600; classtype:attempted-recon; sid:9900602; rev:1; metadata: policy time_integrity, protocol NTP, confidence Medium, response_action alert_only;)


